@model QuanLyQuanCaPhe.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-center" style="min-height:80vh;">
    <div style="width:100%;max-width:440px;">

        <!-- Stepper -->
        <div class="d-flex justify-content-center align-items-center gap-2 mb-4">
            <div class="d-flex flex-column align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:36px;height:36px;background:var(--color-primary);color:#fff;">1</div>
                <small class="mt-1 fw-semibold" style="color:var(--color-primary);">Nhập email</small>
            </div>
            <div style="width:50px;height:2px;background:#dee2e6;margin-bottom:18px;"></div>
            <div class="d-flex flex-column align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:36px;height:36px;background:#dee2e6;color:#999;">2</div>
                <small class="mt-1 text-muted">Xác nhận OTP</small>
            </div>
            <div style="width:50px;height:2px;background:#dee2e6;margin-bottom:18px;"></div>
            <div class="d-flex flex-column align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:36px;height:36px;background:#dee2e6;color:#999;">3</div>
                <small class="mt-1 text-muted">Mật khẩu mới</small>
            </div>
        </div>

        <!-- Card -->
        <div class="card shadow-sm">
            <div class="card-header text-center" style="background:var(--color-primary);color:#fff;">
                <i class="bi bi-envelope-arrow-up me-2"></i>
                <span class="fw-semibold">Quên mật khẩu</span>
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-4 text-center">
                    Nhập email đã đăng ký — hệ thống sẽ gửi mã OTP 6 chữ số đến hộp thư của bạn.
                </p>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control"
                                   placeholder="email@cafe.vn"
                                   autocomplete="email" autofocus />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-coffee">
                            <i class="bi bi-send me-1"></i>Gửi mã OTP
                        </button>
                    </div>
                </form>

                <div class="text-center small">
                    <a asp-action="Login" class="text-decoration-none" style="color:var(--color-primary);">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
