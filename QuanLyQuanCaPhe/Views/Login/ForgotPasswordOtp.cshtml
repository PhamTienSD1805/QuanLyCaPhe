@model QuanLyQuanCaPhe.Models.ForgotPasswordOtpViewModel
@{
    ViewData["Title"] = "Gửi mã OTP";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-center" style="min-height:80vh;">
    <div style="width:100%;max-width:440px;">

        <!-- Brand -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:72px;height:72px;background:var(--color-primary);">
                <i class="bi bi-shield-lock-fill fs-2 text-white"></i>
            </div>
            <h4 class="fw-bold mb-1" style="color:var(--color-primary);">Xác thực OTP</h4>
            <p class="text-muted small">Hệ thống sẽ gửi mã OTP 6 chữ số đến email của bạn</p>
        </div>

        <!-- OTP Info box -->
        <div class="alert alert-info d-flex gap-2 align-items-start mb-3">
            <i class="bi bi-info-circle-fill mt-1 flex-shrink-0"></i>
            <div class="small">
                <strong>OTP là gì?</strong><br/>
                OTP (One-Time Password) là mã xác thực <strong>dùng một lần</strong>, có hiệu lực
                <strong>5 phút</strong>. Mã này sẽ được gửi đến email đã đăng ký trong hệ thống.
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header text-center" style="background:var(--color-primary);color:#fff;">
                <span class="fw-semibold"><i class="bi bi-envelope-check me-2"></i>Nhận mã OTP qua email</span>
            </div>
            <div class="card-body p-4">
                <form asp-action="ForgotPasswordOtp" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-color:#d5c4b8;">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control" placeholder="email@cafe.vn"
                                   autocomplete="email" autofocus />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                        <div class="form-text">
                            Nhập email đã đăng ký trong hệ thống để nhận mã OTP.
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-coffee">
                            <i class="bi bi-send me-1"></i>Gửi mã OTP
                        </button>
                    </div>
                </form>

                <hr class="my-3" />

                <div class="d-flex justify-content-between small">
                    <a asp-action="Login" class="text-decoration-none" style="color:var(--color-primary);">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập
                    </a>
                    <a asp-action="ForgotPassword" class="text-decoration-none" style="color:var(--color-primary);">
                        <i class="bi bi-key me-1"></i>Nhận mật khẩu mới ngay
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
