@model QuanLyQuanCaPhe.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-center" style="min-height:80vh;">
    <div style="width:100%;max-width:440px;">

        <!-- Stepper -->
        <div class="d-flex justify-content-center align-items-center gap-2 mb-4">
            <div class="d-flex flex-column align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:36px;height:36px;background:#28a745;color:#fff;">
                    <i class="bi bi-check-lg"></i>
                </div>
                <small class="mt-1 text-success fw-semibold">Nhập email</small>
            </div>
            <div style="width:50px;height:2px;background:#28a745;margin-bottom:18px;"></div>
            <div class="d-flex flex-column align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:36px;height:36px;background:#28a745;color:#fff;">
                    <i class="bi bi-check-lg"></i>
                </div>
                <small class="mt-1 text-success fw-semibold">Xác nhận OTP</small>
            </div>
            <div style="width:50px;height:2px;background:var(--color-primary);margin-bottom:18px;"></div>
            <div class="d-flex flex-column align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:36px;height:36px;background:var(--color-primary);color:#fff;">3</div>
                <small class="mt-1 fw-semibold" style="color:var(--color-primary);">Mật khẩu mới</small>
            </div>
        </div>

        <!-- Card -->
        <div class="card shadow-sm">
            <div class="card-header text-center" style="background:var(--color-primary);color:#fff;">
                <i class="bi bi-key-fill me-2"></i>
                <span class="fw-semibold">Đặt lại mật khẩu</span>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-success d-flex gap-2 align-items-center py-2 mb-4">
                    <i class="bi bi-shield-check-fill flex-shrink-0"></i>
                    <span class="small">OTP đã được xác nhận! Hãy đặt mật khẩu mới cho tài khoản.</span>
                </div>

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="OtpId" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <!-- Mật khẩu mới -->
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="NewPassword" type="password" id="new-pw"
                                   class="form-control" placeholder="Tối thiểu 4 ký tự"
                                   autocomplete="new-password" autofocus />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePw('new-pw','eye1')">
                                <i class="bi bi-eye" id="eye1"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>

                        <!-- Strength meter -->
                        <div class="mt-2">
                            <div class="progress" style="height:4px;">
                                <div id="pw-strength-bar" class="progress-bar" style="width:0%;"></div>
                            </div>
                            <small id="pw-strength-label" class="text-muted"></small>
                        </div>
                    </div>

                    <!-- Xác nhận mật khẩu -->
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" type="password" id="confirm-pw"
                                   class="form-control" placeholder="Nhập lại mật khẩu mới"
                                   autocomplete="new-password" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePw('confirm-pw','eye2')">
                                <i class="bi bi-eye" id="eye2"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Đặt lại mật khẩu
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center text-muted small">
                <i class="bi bi-shield-lock me-1"></i>
                Kết nối bảo mật — Mật khẩu được mã hóa an toàn
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function togglePw(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon  = document.getElementById(iconId);
        if (!input) return;
        input.type = input.type === 'password' ? 'text' : 'password';
        icon?.classList.toggle('bi-eye');
        icon?.classList.toggle('bi-eye-slash');
    }

    // Password strength meter
    document.getElementById('new-pw')?.addEventListener('input', function () {
        const val = this.value;
        const bar = document.getElementById('pw-strength-bar');
        const lbl = document.getElementById('pw-strength-label');
        if (!bar || !lbl) return;

        let score = 0;
        if (val.length >= 4)  score++;
        if (val.length >= 8)  score++;
        if (/[A-Z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;

        const levels = [
            { w: '0%',   cls: '',           label: '' },
            { w: '25%',  cls: 'bg-danger',  label: 'Yếu' },
            { w: '50%',  cls: 'bg-warning', label: 'Trung bình' },
            { w: '75%',  cls: 'bg-info',    label: 'Khá' },
            { w: '90%',  cls: 'bg-success', label: 'Mạnh' },
            { w: '100%', cls: 'bg-success', label: 'Rất mạnh ✓' },
        ];
        const lvl = levels[Math.min(score, 5)];
        bar.style.width    = lvl.w;
        bar.className      = 'progress-bar ' + lvl.cls;
        lbl.textContent    = lvl.label;
        lbl.className      = 'small ' + (score < 2 ? 'text-danger' : score < 4 ? 'text-warning' : 'text-success');
    });
    </script>
}
