@model QuanLyQuanCaPhe.Models.Drink
@{
    ViewData["Title"] = "Chi tiết đồ uống";
}

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0"><i class="bi bi-cup-straw me-2 text-info"></i>Chi tiết đồ uống</h4>
</div>

<div class="row g-3" style="max-width:640px;">
    <div class="col-auto">
        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <img src="@Model.Image" alt="@Model.Name" style="width:140px;height:140px;object-fit:cover;border-radius:12px;" class="shadow-sm" />
        }
        else
        {
            <div class="bg-light d-flex align-items-center justify-content-center rounded" style="width:140px;height:140px;">
                <i class="bi bi-cup-straw fs-1 text-secondary"></i>
            </div>
        }
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-1">@Model.Name</h5>
                <div class="text-muted small mb-2">Danh mục #@Model.CategoryId — @ViewBag.CategoryName</div>
                <div class="fs-5 fw-bold text-success mb-2">@Model.Price.ToString("N0") đ</div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted">@Model.Description</p>
                }
                <span class="badge @(Model.Active ? "bg-success" : "bg-secondary")">
                    @(Model.Active ? "Đang bán" : "Đã ngưng")
                </span>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    @if (User.IsInRole("Manager"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
            <i class="bi bi-pencil me-1"></i>Sửa
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">
            <i class="bi bi-trash me-1"></i>Ngưng bán
        </a>
    }
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại</a>
</div>
