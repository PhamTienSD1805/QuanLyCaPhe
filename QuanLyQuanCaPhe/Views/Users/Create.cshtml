@model QuanLyQuanCaPhe.Models.UserViewModel
@{
    ViewData["Title"] = "Thêm nhân viên";
}

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0"><i class="bi bi-person-plus me-2 text-primary"></i>Thêm nhân viên mới</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width:560px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-medium"></label>
                <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-medium"></label>
                <input asp-for="Email" type="email" class="form-control" placeholder="nhanvien@cafe.vn" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-medium"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Tối thiểu 4 ký tự" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-medium"></label>
                <input asp-for="Phone" class="form-control" placeholder="0901234567" />
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label fw-medium"></label>
                <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select"></select>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Tài khoản hoạt động</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
