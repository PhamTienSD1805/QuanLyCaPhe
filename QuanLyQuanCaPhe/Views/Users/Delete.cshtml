@model QuanLyQuanCaPhe.Models.User
@{
    ViewData["Title"] = "Khóa tài khoản";
}

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0 text-danger"><i class="bi bi-person-x me-2"></i>Xác nhận khóa tài khoản</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width:480px;">
    <div class="card-body">
        <p class="mb-2">Bạn có chắc muốn <strong>khóa</strong> tài khoản sau?</p>
        <div class="border rounded p-3 bg-light mb-3">
            <div class="fw-bold">@Model.FullName</div>
            <div class="text-muted small">@Model.Email</div>
            <span class="badge @(Model.Role ? "bg-warning text-dark" : "bg-secondary") mt-1">
                @(Model.Role ? "Quản lý" : "Nhân viên")
            </span>
        </div>
        <div class="alert alert-warning py-2 small">
            <i class="bi bi-info-circle me-1"></i>Tài khoản bị khóa sẽ không thể đăng nhập nhưng dữ liệu không bị mất.
        </div>
        <form asp-action="Delete" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-person-x me-1"></i>Xác nhận khóa
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </form>
    </div>
</div>
