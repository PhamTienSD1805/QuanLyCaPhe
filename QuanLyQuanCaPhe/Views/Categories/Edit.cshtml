@model QuanLyQuanCaPhe.Models.Category
@{
    ViewData["Title"] = "Sửa danh mục";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-secondary btn-sm">← Quay lại</a>
    <h2 class="mb-0">Sửa danh mục</h2>
</div>

<div class="card shadow-sm" style="max-width:480px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Tên danh mục</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Đang hoạt động</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Cập nhật</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
